{
  "name": "focus-tracker",
  "version": "0.1.0",
  "description": "Desktop focus / attention tracker",
  "main": "main.js",
  "author": "Your Name",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
  "appId": "com.yourname.focustracker",
  "productName": "Focus Tracker",
  "files": ["**/*"],
  "mac": {
    "category": "public.app-category.productivity",
    "identity": null
  },
  "win": { "target": "nsis" },
  "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}